							"raw": "{{base_url}}/api/products?category=&search=&sort=newest&page=1&limit=12",
							"host": ["{{base_url}}"],
							"path": ["api", "products"],
							"query": [
								{ "key": "category", "value": "", "description": "فلترة حسب slug التصنيف" },
								{ "key": "search", "value": "", "description": "بحث في الاسم والوصف" },
								{ "key": "sort", "value": "newest", "description": "newest | price_asc | price_desc | name_asc" },
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "12", "description": "max: 50" }
							]
						},
						"description": "جلب المنتجات المنشورة مع إمكانية التصفية والترتيب والبحث\n\n**الاستجابة:** 200\n```json\n{\n  \"success\": true,\n  \"data\": [\n    {\n      \"id\": \"...\",\n      \"name\": \"...\",\n      \"slug\": \"...\",\n      \"price\": 99.99,\n      \"images\": [\"...\"],\n      \"stock\": 10,\n      \"category\": { \"name\": \"...\", \"slug\": \"...\" }\n    }\n  ],\n  \"pagination\": {\n    \"page\": 1,\n    \"limit\": 12,\n    \"total\": 50,\n    \"totalPages\": 5\n  }\n}\n```"
					}
				},
				{
					"name": "منتج حسب Slug",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/products/{{productSlug}}",
							"host": ["{{base_url}}"],
							"path": ["api", "products", "{{productSlug}}"]
						},
						"description": "جلب منتج محدد باستخدام الـ slug\n\n**الاستجابة:** 200\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"...\",\n    \"name\": \"...\",\n    \"slug\": \"...\",\n    \"description\": \"...\",\n    \"price\": 99.99,\n    \"images\": [...],\n    \"stock\": 10,\n    \"category\": { \"name\": \"...\", \"slug\": \"...\" },\n    \"createdAt\": \"...\"\n  }\n}\n```"
					}
